---
import ExecutiveImpactCarousel, {
  type TeamMember,
} from "../../components/ui/executive-impact-carousel";
import FadeIn from "../../components/ui/fade-in";
import TextBlockAnimation from "../../components/ui/text-block-animation";

const members: TeamMember[] = [
  {
    id: "1",
    name: "Varsha",
    role: "Community Member",
    image: "/team-nobg/varsha.jpg",
  },
  {
    id: "2",
    name: "Manas",
    role: "Community Member",
    image: "/team-nobg/manas_s.jpg",
  },
  {
    id: "3",
    name: "Hitha",
    role: "Community Member",
    image: "/team-nobg/hitha_badikillaya_s_u.jpg",
  },
  {
    id: "4",
    name: "Yash Laxman",
    role: "Community Member",
    image: "/team-nobg/yash_laxman.jpg",
  },
  {
    id: "5",
    name: "Mustafa",
    role: "Community Member",
    image: "/team-nobg/mustafa_asthikodi.jpg",
  },
  {
    id: "6",
    name: "Vivek",
    role: "Community Member",
    image: "/team-nobg/vivek_neeralagi.jpg",
  },
];
---

<section class="relative w-full overflow-hidden bg-[#E6FDE2] lg:h-screen">
  <div
    class="relative flex h-[100svh] w-full flex-col md:grid md:h-full md:grid-cols-2"
  >
    <!-- Images Carousel (Background on mobile, Right column on desktop) -->
    <div
      class="absolute inset-0 z-0 flex h-full w-full items-center justify-center overflow-hidden bg-[#0ade4a] px-2 md:relative md:z-auto md:px-8 xl:px-12"
    >
      <!-- Blackish shadow overlay (Mobile Only) to avoid collision -->
      <div
        class="pointer-events-none absolute inset-0 z-10 bg-black/60 md:hidden"
      >
      </div>
      <ExecutiveImpactCarousel client:load members={members} />
    </div>

    <!-- Text (Foreground on mobile, Left column on desktop) -->
    <div
      class="pointer-events-none absolute inset-0 z-20 flex w-full flex-col justify-center px-6 pt-28 pb-20 sm:px-10 md:pointer-events-auto md:relative md:z-auto md:bg-[#E6FDE2] md:pt-24 md:pb-0 lg:pl-32"
    >
      <div
        class="pointer-events-auto flex flex-col text-5xl sm:text-6xl md:text-6xl lg:gap-3 lg:text-7xl"
      >
        <TextBlockAnimation client:load blockColor="#0ade4a">
          <h2
            class="w-full font-black text-white drop-shadow-lg md:text-black md:drop-shadow-none"
          >
            MEET THE
          </h2>
        </TextBlockAnimation>

        <TextBlockAnimation client:load delay={0.2} blockColor="#000">
          <h2
            class="md:text-primary w-full font-black text-[#0ade4a] drop-shadow-lg md:drop-shadow-none"
          >
            MINDS BEHIND
          </h2>
        </TextBlockAnimation>

        <TextBlockAnimation client:load delay={0.45} blockColor="#0ade4a">
          <h2
            class="w-full font-black text-white drop-shadow-lg md:text-black md:drop-shadow-none"
          >
            THE CODE
          </h2>
        </TextBlockAnimation>
      </div>

      <div
        class="pointer-events-auto my-6 w-full max-w-[500px] text-lg font-medium text-gray-200 drop-shadow-md md:my-10 md:text-xl md:text-gray-800 md:drop-shadow-none"
      >
        <FadeIn client:load delay={0.65}>
          <p>
            From ideation to deployment, get to know the team building the
            future at SOSC
          </p>
        </FadeIn>
      </div>
    </div>
  </div>
</section>
